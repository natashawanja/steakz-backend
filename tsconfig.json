{
    "compilerOptions": {
      "rootDir": "./src",
      "outDir": "./dist",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "target": "ESNext",
      "types": ["node"],
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "declaration": true
    },
    "include": ["src/**/*"]
  }